{
  "name": "zk-age-proof",
  "version": "1.0.0",
  "description": "A zk-SNARK smart contract to prove age > 18 without revealing the actual age",
  "main": "index.js",
  "scripts": {
    "test": "hardhat test",
    "compile": "hardhat compile",
    "circuit:compile": "circom circuits/ageProof.circom --r1cs --wasm --sym",
    "circuit:setup": "node scripts/setup.js",
    "circuit:proof": "node scripts/generateProof.js",
    "circuit:export": "node scripts/exportVerifier.js",
    "start": "npx hardhat node",
    "deploy": "hardhat run scripts/deploy.js --network localhost",
    "verify-test": "hardhat run scripts/verifyTest.js --network localhost"
  },
  "keywords": [
    "zk-SNARK",
    "Circom",
    "SnarkJS",
    "Hardhat",
    "Ethereum"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "circom_runtime": "^0.1.25",
    "circomlib": "^2.0.5",
    "snarkjs": "^0.7.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^3.0.0",
    "chai": "^4.3.7",
    "ethers": "^6.9.0",
    "hardhat": "^2.19.0"
  }
}
